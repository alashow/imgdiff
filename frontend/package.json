{
  "name": "imgdiff",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:standalone": "vue-tsc --noEmit && vite build --mode standalone --outDir dist-standalone",
    "preview": "vite preview",
    "preview:standalone": "vite preview --outDir dist-standalone"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-singlefile": "^2.2.0",
    "vue-tsc": "^2.1.10"
  }
}
